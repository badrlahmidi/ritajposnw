# ═══════════════════════════════════════════════════════════
#  RITAJ SMART POS — Variables d'environnement
#  Copiez ce fichier en .env et adaptez les valeurs
# ═══════════════════════════════════════════════════════════

# Serveur
PORT=3000
BASE_PATH=/pos

# Sécurité JWT — OBLIGATOIRE : changez cette clé en production !
JWT_SECRET=CHANGEZ-CETTE-CLE-EN-PRODUCTION
JWT_EXPIRES=12h

# CORS — origines autorisées (séparées par des virgules, vide = même origine)
CORS_ORIGINS=

# Identité produit
APP_NAME=RITAJ SMART POS
APP_VERSION=4.1.0
